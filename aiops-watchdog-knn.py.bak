#!/usr/bin/env python3

"""
Script: disk_anomaly_knn.py
Author: Beth Fox
Purpose: Monitor disk usage and detect anomalies using KNN from the PyOD library.
"""
import os
import time
import psutil
import numpy as np
from datetime import datetime
from threading import Thread
from pyod.models.knn import KNN
from prometheus_client import start_http_server, Gauge
from flask import Flask, request

# === CONFIG ===
SAMPLE_INTERVAL = 10         # Seconds between checks
WINDOW_SIZE = 20             # How many samples to train on
PORT = int(os.getenv("WATCHDOG_PORT", 8011))
APPROVE_TOKEN = os.getenv("APPROVE_TOKEN", "changeme")

# === Prometheus metric ===
anomaly_metric = Gauge("disk_anomaly_prediction", "1 if anomaly detected, else 0")

# === Start Prometheus HTTP server ===
start_http_server(PORT)

# === Flask app for approval endpoint ===
app = Flask(__name__)

@app.route("/approve", methods=["GET"])
def approve_action():
    token = request.args.get("token")
    if token == APPROVE_TOKEN:
        os.system("sudo systemctl restart loki.service")
        print("✅ Loki restart approved via Slack")
        return "Approved and executed"
    else:
        print("❌ Invalid approval token attempt")
        return "Invalid token", 403

def run_flask():
    app.run(host="0.0.0.0", port=8020)  # run Flask on separate port

# Start Flask in background thread
thread = Thread(target=run_flask, daemon=True)
thread.start()

# === History buffer for disk usage samples ===
disk_usage_history = []
model = KNN()

print("✅ Disk anomaly monitor with approval endpoint is running...")

while True:
    usage = psutil.disk_usage("/").percent
    timestamp = datetime.now()
    print(f"[{timestamp}] Current disk usage: {usage:.2f}%")

    disk_usage_history.append([usage])

    if len(disk_usage_history) >= WINDOW_SIZE:
        X = np.array(disk_usage_history[-WINDOW_SIZE:])
        model.fit(X)

        prediction = model.predict([[usage]])[0]
        score = model.decision_function([[usage]])[0]

        if prediction == 1:
            print(f"[{timestamp}] 🚨 Anomaly detected! Usage = {usage:.2f}% | Score = {score:.4f}")
            anomaly_metric.set(1)
        else:
            print(f"[{timestamp}] ✅ Normal. Score = {score:.4f}")
            anomaly_metric.set(0)

    time.sleep(SAMPLE_INTERVAL)
